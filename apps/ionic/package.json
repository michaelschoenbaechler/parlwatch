{
  "name": "@parlwatch/ionic",
  "version": "2026.4.1",
  "author": "Michael Schönbächler",
  "homepage": "https://github.com/michaelschoenbaechler",
  "description": "Easy access for everyone to parliamentary data",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prd": "ng build --configuration=production",
    "ios:sync": "npx cap sync ios",
    "ios:fastlane:install": "cd ios/App && bundle install",
    "ios:prepare": "npm run build:prd && npm run ios:sync",
    "ios:deploy:testflight": "npm run ios:prepare && cd ios/App && bundle exec fastlane deploy_testflight",
    "ios:deploy:appstore": "npm run ios:prepare && cd ios/App && bundle exec fastlane deploy_appstore",
    "lint": "ng lint && npx prettier -c \"src/**/*.{ts,html}\"",
    "lint:fix": "ng lint --fix",
    "prettier": "npm run prettier:fix",
    "prettier:fix": "npx prettier --write \"src/**/*.{ts,html}\"",
    "i18n:extract": "transloco-keys-manager extract --remove-extra-keys --sort",
    "i18n:find": "transloco-keys-manager find",
    "changelog:generate": "conventional-changelog -p angular",
    "test": "ng test",
    "test:ci": "ng test --browsers=ChromeHeadless --watch=false --code-coverage",
    "test:coverage": "ng test --code-coverage"
  },
  "private": true,
  "overrides": {
    "handlebars": "4.7.9",
    "tmp": "^0.2.4",
    "webpack": "5.105.4",
    "rollup": "4.59.0",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.11",
    "undici": "7.24.2",
    "yauzl": "3.2.1",
    "picomatch": "4.0.4"
  },
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@capacitor/app": "^7.1.1",
    "@capacitor/browser": "^7.0.3",
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.3",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/keyboard": "^7.0.4",
    "@capacitor/status-bar": "^7.0.4",
    "@ionic/angular": "^8.8.1",
    "@ionic/cli": "^7.2.1",
    "@ionic/core": "^8.8.1",
    "@ionic/storage-angular": "^4.0.0",
    "@jsverse/transloco": "^7.6.1",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/signals": "^21.0.1",
    "ionicons": "^7.2.2",
    "lodash": "^4.17.21",
    "rxjs": "~7.8.1",
    "swissparl": "^0.6.2",
    "tslib": "^2.2.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular-eslint/builder": "~19.3.0",
    "@angular-eslint/eslint-plugin": "~19.3.0",
    "@angular-eslint/eslint-plugin-template": "~19.3.0",
    "@angular-eslint/template-parser": "~19.3.0",
    "@angular/cli": "^21.2.1",
    "@angular/compiler": "^21.2.4",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/language-service": "^21.2.4",
    "@capacitor/cli": "^7.4.5",
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "@ionic/angular-toolkit": "^12.3.0",
    "@jsverse/transloco-keys-manager": "^7.1.0",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "conventional-changelog": "^7.1.1",
    "eslint": "^9.26.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "48.0.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^8.0.3",
    "jasmine-core": "^6.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "prettier": "^3.7.4",
    "ts-node": "~10.9.2",
    "typescript": "~5.9.3"
  }
}
