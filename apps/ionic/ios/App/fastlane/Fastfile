default_platform(:ios)

def required_env!(keys)
  missing = keys.select { |key| ENV[key].to_s.strip.empty? }
  return if missing.empty?

  UI.user_error!("Missing required environment variable(s): #{missing.join(', ')}")
end

def app_store_connect_api_key_from_env
  required_env!(%w[APP_STORE_CONNECT_KEY_ID APP_STORE_CONNECT_ISSUER_ID APP_STORE_CONNECT_API_KEY])

  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY"],
    is_key_content_base64: true
  )
end

platform :ios do
  private_lane :set_ci_marketing_version do
    marketing_version = ENV["IOS_MARKETING_VERSION"].to_s.strip

    if marketing_version.empty? && ENV["CI"] == "true"
      now = Time.now
      marketing_version = now.strftime("%Y.%-m.%-d")
    end

    return if marketing_version.empty?

    increment_version_number(
      xcodeproj: "App.xcodeproj",
      version_number: marketing_version
    )
  end

  private_lane :set_ci_build_number do
    build_number = ENV["IOS_BUILD_NUMBER"].to_s.strip
    build_number = ENV["GITHUB_RUN_ID"].to_s.strip if build_number.empty?
    build_number = ENV["GITHUB_RUN_NUMBER"].to_s.strip if build_number.empty?
    return if build_number.empty?

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: build_number
    )
  end

  private_lane :build_release do
    app_identifier = ENV.fetch("APP_IDENTIFIER", "ch.michaelschoenbaechler.parlwatch")
    provisioning_profile_name = ENV["IOS_PROVISIONING_PROFILE_NAME"].to_s.strip
    team_id = ENV.fetch("APPLE_TEAM_ID", "65DUBW68Z2")
    required_env!(%w[IOS_PROVISIONING_PROFILE_NAME])

    export_options = {
      "method" => "app-store",
      "signingStyle" => "manual",
      "teamID" => team_id,
      "provisioningProfiles" => {
        app_identifier => provisioning_profile_name
      }
    }

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      clean: true,
      export_method: "app-store",
      export_options: export_options,
      xcargs: %Q(IOS_PROVISIONING_PROFILE_NAME="#{provisioning_profile_name}"),
      skip_profile_detection: true
    )
  end

  desc "Build and upload an iOS build to TestFlight"
  lane :deploy_testflight do
    api_key = app_store_connect_api_key_from_env
    set_ci_marketing_version
    set_ci_build_number
    build_release

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Build and upload an iOS build to App Store Connect"
  lane :deploy_appstore do
    api_key = app_store_connect_api_key_from_env
    set_ci_marketing_version
    set_ci_build_number
    build_release

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      force: true
    )
  end
end
