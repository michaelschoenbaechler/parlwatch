{
  "name": "parlwatch",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "dev:ionic": "npm run start --workspace @parlwatch/ionic",
    "start": "npm run start --workspace @parlwatch/ionic",
    "build:ionic": "npm run build --workspace @parlwatch/ionic",
    "build": "npm run build --workspace @parlwatch/ionic",
    "build:prd": "npm run build:prd --workspace @parlwatch/ionic",
    "ios:sync": "npm run ios:sync --workspace @parlwatch/ionic",
    "ios:fastlane:install": "npm run ios:fastlane:install --workspace @parlwatch/ionic",
    "ios:prepare": "npm run ios:prepare --workspace @parlwatch/ionic",
    "ios:deploy:testflight": "npm run ios:deploy:testflight --workspace @parlwatch/ionic",
    "ios:deploy:appstore": "npm run ios:deploy:appstore --workspace @parlwatch/ionic",
    "lint": "npm run lint --workspace @parlwatch/ionic",
    "lint:fix": "npm run lint:fix --workspace @parlwatch/ionic",
    "prettier": "npm run prettier --workspace @parlwatch/ionic",
    "prettier:fix": "npm run prettier:fix --workspace @parlwatch/ionic",
    "i18n:extract": "npm run i18n:extract --workspace @parlwatch/ionic",
    "i18n:find": "npm run i18n:find --workspace @parlwatch/ionic",
    "changelog:generate": "npm run changelog:generate --workspace @parlwatch/ionic",
    "test": "npm run test --workspace @parlwatch/ionic",
    "test:ci": "npm run test:ci --workspace @parlwatch/ionic",
    "test:coverage": "npm run test:coverage --workspace @parlwatch/ionic"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "husky": "^8.0.3"
  }
}
