# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*
node_modules/

/.angular
/apps/*/.angular
/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode/*
!/.vscode/extensions.json
/coverage
/apps/*/coverage
/dist
.env
.env.local
.env.*.local
/platforms
/plugins
/apps/ionic/www
/apps/ionic/ios/App/fastlane/report.xml
/apps/ionic/ios/App/fastlane/Preview.html
/apps/ionic/ios/App/fastlane/test_output
/apps/ionic/ios/App/fastlane/screenshots
